// NTG Modular Platform — single schema, logical sections per bundle
// @auth-membership | @tournaments-leagues | @socials-gallery

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  PLAYER
  MODERATOR
  ADMIN
}

enum GameSlug {
  VALORANT
  CS2
  EA_FC26
  OTHER
}

enum TournamentStatus {
  DRAFT
  REGISTRATION_OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BracketType {
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  WALKOVER
  BYE
}

enum ParticipantType {
  USER
  TEAM
}

enum PlacementRole {
  CHAMPION
  RUNNER_UP
  THIRD
  MVP
}

enum LeaderboardScope {
  TOWN
  SEASON
  ALL_TIME
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── @auth-membership ────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String?   @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  passwordHash     String?
  phone            String?   @unique
  riotPuuid        String?   @unique
  riotGameName     String?
  riotTagLine      String?
  riotRegion       String?
  signupCompleted  Boolean   @default(false)
  role             UserRole  @default(PLAYER)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  playerProfile PlayerProfile?
  emailOtps     EmailOtp[]

  registrations TournamentRegistration[]
  matchSlots    MatchParticipant[]
  placements    TournamentPlacement[]
  leaderboard   LeaderboardEntry[]
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int      @default(0)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([email, expiresAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model PlayerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  town        String   @default("Mangaluru")
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gameLinks GameIdentity[]
}

model GameIdentity {
  id         String   @id @default(cuid())
  profileId  String
  profile    PlayerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  game       GameSlug
  platform   String
  externalId String
  verified   Boolean  @default(false)

  @@unique([profileId, game, platform])
}

// ─── @tournaments-leagues ──────────────────────────────────────────────────

model Season {
  id          String       @id @default(cuid())
  label       String
  startsAt    DateTime?
  endsAt      DateTime?
  tournaments Tournament[]
}

model Tournament {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  game            GameSlug
  gameLabel       String?
  seasonId        String?
  season          Season?          @relation(fields: [seasonId], references: [id])
  status          TournamentStatus @default(DRAFT)
  format          BracketType?
  prizePool       Decimal?         @db.Decimal(10, 2)
  prizeNotes      String?
  startsAt        DateTime?
  endsAt          DateTime?
  registrationUrl String?
  hideAfter       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  bracket       Bracket?
  registrations TournamentRegistration[]
  placements    TournamentPlacement[]
}

model TournamentRegistration {
  id                  String             @id @default(cuid())
  tournamentId        String
  tournament          Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamName            String?
  partnerName         String?
  snapshotDisplayName String?
  snapshotRiotId      String?
  snapshotPhone       String?
  status              RegistrationStatus @default(PENDING)
  createdAt           DateTime           @default(now())

  @@unique([tournamentId, userId])
}

model Bracket {
  id           String      @id @default(cuid())
  tournamentId String      @unique
  tournament   Tournament  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  type         BracketType
  totalRounds  Int
  matches      Match[]
}

model Match {
  id                String      @id @default(cuid())
  bracketId         String
  bracket           Bracket     @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  roundNumber       Int
  positionInRound   Int
  bracketSide       String?
  status            MatchStatus @default(SCHEDULED)
  scheduledAt       DateTime?
  nextWinnerMatchId String?
  nextLoserMatchId  String?
  nextWinnerMatch   Match?      @relation("WinnerAdvance", fields: [nextWinnerMatchId], references: [id], onDelete: SetNull)
  nextLoserMatch    Match?      @relation("LoserAdvance", fields: [nextLoserMatchId], references: [id], onDelete: SetNull)
  winnerAdvancesFrom Match[]    @relation("WinnerAdvance")
  loserAdvancesFrom  Match[]    @relation("LoserAdvance")
  participants      MatchParticipant[]
  result            MatchResult?

  @@unique([bracketId, roundNumber, positionInRound, bracketSide])
}

model MatchParticipant {
  id              String          @id @default(cuid())
  matchId         String
  match           Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  slot            Int
  participantType ParticipantType
  userId          String?
  user            User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamLabel       String?
  seed            Int?

  @@unique([matchId, slot])
}

model MatchResult {
  id           String   @id @default(cuid())
  matchId      String   @unique
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  winnerSlot   Int
  scoreSummary String?
  completedAt  DateTime @default(now())
}

model TournamentPlacement {
  id           String        @id @default(cuid())
  tournamentId String
  tournament   Tournament    @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  role         PlacementRole
  userId       String?
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamLabel    String?

  @@unique([tournamentId, role])
}

model LeaderboardEntry {
  id             String           @id @default(cuid())
  game           GameSlug
  scope          LeaderboardScope @default(TOWN)
  seasonId       String?
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  points         Int              @default(0)
  wins           Int              @default(0)
  losses         Int              @default(0)
  mmr            Int?
  premierRating  Int?
  rankTier       String?
  rankTierId     Int?
  peakMmr        Int?
  rank           Int?
  lastSyncedAt   DateTime?
  updatedAt      DateTime         @updatedAt

  @@unique([game, scope, seasonId, userId])
}

// ─── @socials-gallery ───────────────────────────────────────────────────────

model GallerySource {
  id       String        @id @default(cuid())
  platform String
  handle   String
  active   Boolean       @default(true)
  items    GalleryItem[]

  @@unique([platform, handle])
}

model GalleryItem {
  id           String        @id @default(cuid())
  sourceId     String
  source       GallerySource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  externalId   String
  mediaType    String
  embedUrl     String?
  thumbnailUrl String?
  caption      String?
  publishedAt  DateTime?
  pinned       Boolean       @default(false)

  @@unique([sourceId, externalId])
}
